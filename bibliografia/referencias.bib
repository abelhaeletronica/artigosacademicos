@article{caysesIstoNaoUma2014,
  title = {Isto não é uma obra: {{Arte}} e ditadura},
  shorttitle = {Isto não é uma obra},
  author = {Cayses, Julia Buenaventura Valencia de},
  date = {2014-04},
  journaltitle = {Estudos Avançados},
  shortjournal = {Estud. av.},
  volume = {28},
  number = {80},
  pages = {115--128},
  issn = {0103-4014},
  doi = {10.1590/S0103-40142014000100011},
  url = {http://www.scielo.br/scielo.php?script=sci_arttext&pid=S0103-40142014000100011&lng=pt&tlng=pt},
  urldate = {2025-08-26},
  abstract = {O presente texto faz um percurso pela arte durante o período da ditadura militar no Brasil, analisando especificamente as propostas de obra como ação ou desmaterialização da obra de arte. Partindo da arte abstrata dos anos 1950 e 1960, da teoria do não objeto de Ferreira Gullar e das propostas do crítico Mário Pedrosa, o ensaio aborda obras de Willys de Castro, Ligya Clark, Artur Barrio, Cildo Meireles, Antônio Manuel e o grupo 3Nós3, assim como faz uma incursão pelo chamado boicote à Bienal de São Paulo de 1969.            ,               This essay gives a panorama of art during the period of military dictatorship in Brazil; specifically, it studies the construction of art as an action and dematerialization of the artwork. Starting with the abstract art of the 50s and 60s, the Theory of Non-object of Ferreira Gullar and the papers of Mário Pedrosa, the essay focuses on works of Willys de Castro, Ligya Clark, Artur Barrio, Meireles, Manuel Antonio and 3NÓS3 group, as well into the so-called Boycott of Bienal de São Paulo in 1969.}
}

@article{gullarManifestoNeoconcreto1959,
  entrysubtype = {newspaper},
  title = {Manifesto Neoconcreto},
  shorttitle = {Acervo},
  author = {Gullar, Ferreira},
  date = {1959-03-21},
  journaltitle = {Jornal do Brasil},
  pages = {2},
  location = {Rio de Janeiro},
  url = {https://portal.lygiaclark.org.br/acervo/67348/manifesto-neoconcreto},
  urldate = {2025-07-29},
  abstract = {Publicado no Suplemento Dominical do Jornal do Brasil de 21 de março de 1959 por ocasião da I Exposição Neoconcreta, realizada no MAM/RJ (1959), o manifesto, escrito por Ferreira Gullar e assinado pelos artistas que participaram da exposição, o manifesto defende uma reinterpretação da arte geométrica (não figurativa) e destaca a importância de artistas como Piet Mondrian e Kazimir Malevich como referências essenciais do movimento que se rebelou especificamente contra as ideias propostas em São Paulo. O documento também insiste no conceito de independência artística em termos de conhecimento objetivo e prático, e compara a arte a organismos vivos, sugerindo que essa perspectiva só pode ser obtida por meios fenomenológicos. Referindo-se a temas da literatura "neoconcreta", o manifesto afirma que os signatários estão livres de quaisquer princípios dogmáticos, embora descreva certas afinidades em seus trabalhos.},
  langid = {portuguese},
  file = {C:\Users\gassi\Zotero\storage\RP558UX9\manifesto-neoconcreto.html}
}

